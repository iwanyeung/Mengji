{
  "name": "mengji-server",
  "version": "0.1.0",
  "private": true,
  "description": "梦悸（Dream Impulse）MVP 后端服务：录梦、梦析、显化工坊与潜意识星图 API。",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
